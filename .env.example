# ---------------------------------------------------------
# TWITCH AUTHENTICATION
# ---------------------------------------------------------
# dev.twitch.tv/console
CLIENT_ID=
CLIENT_SECRET=

# Twitch https://twitchtokengenerator.com/
# (Put your generated access token here. Make sure it starts with oauth:)
OAUTH_TOKEN=
TWITCH_REFRESH_TOKEN=
REDIRECT_URI=https://twitchtokengenerator.com

# ---------------------------------------------------------
# TWITCH NUMERIC IDs (Required for EventSub/Helix)
# ---------------------------------------------------------
# Your Bot's numeric ID (e.g., 987654321)
BOT_USER_ID=

# Your personal channel's numeric ID (e.g., 123456789)
CHAT_CHANNEL_USER_ID=

# ---------------------------------------------------------
# GOOGLE AI STUDIO (Gemini)
# ---------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------
# UNUSED / ARCHIVED (StreamElements)
# ---------------------------------------------------------
# ACCOUNT_ID=
# JWT_TOKEN=
# OVERLAY_TOKEN=